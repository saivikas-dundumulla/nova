# ============================================================
# Nova Ombuds Assistant — environment configuration template
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================

# ---- App / server ----
APP_NAME=nova-ombuds
APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:8501

# ---- Session / JWT (stub auth) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_JWT_SECRET=change-me-to-a-long-random-string
SESSION_JWT_ALG=HS256
SESSION_TTL_MINUTES=480

# ---- Stub user store ----
# JSON dict: {"username": {"password_hash": "<bcrypt>", "role": "enduser|ombuds", "email": "..."}}
# Generate a bcrypt hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('secret'))"
# The demo default below has two users: enduser1/enduser1 and ombuds1/ombuds1.
AUTH_USERS_JSON={"enduser1":{"password_hash":"$2b$12$1XbHG6YggjMT7NGQLBxsyuBVPaZZab/xUD72tqwt.PACSdCPdtkR.","role":"enduser","email":"enduser1@example.com"},"ombuds1":{"password_hash":"$2b$12$EsiD2cpNY92bM3r2ZnJTAO/dorAJbEcSixPLEVqthag3dUEXuQw5m","role":"ombuds","email":"ombuds1@example.com"}}

# ---- Azure OpenAI (LLM) ----
AZURE_OPENAI_ENDPOINT=https://novaapillm.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-chat-latest
AZURE_OPENAI_TEMPERATURE=0.1

# ---- Azure AI Search (unified ServiceNow + Confluence index) ----
AZURE_SEARCH_ENDPOINT=https://novasearch.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=ombuds-knowledge
# Field mapping (adjust to your real schema — placeholders until confirmed)
AZURE_SEARCH_FIELD_SOURCE_TYPE=source_type
AZURE_SEARCH_FIELD_INCIDENT_NUMBER=incident_number
AZURE_SEARCH_FIELD_TITLE=title
AZURE_SEARCH_FIELD_CONTENT=content
AZURE_SEARCH_FIELD_URL=url
AZURE_SEARCH_SEMANTIC_CONFIG=default
AZURE_SEARCH_TOP_K=8

# ---- Kibana / Elasticsearch ----
KIBANA_URL=https://test-elasticsearch:9200
KIBANA_API_KEY=
# Elasticsearch index pattern used by kibana_search
KIBANA_INDEX_PATTERN=java_application_logs*
KIBANA_DEFAULT_TIME_RANGE=1h
KIBANA_TIMEOUT_SECONDS=10
KIBANA_MAX_HITS=25

# ---- Audit / logging ----
AUDIT_LOG_PATH=logs/audit.log
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5
LOG_LEVEL=INFO
# If true, audit events hash the user_id (sha256) before writing.
AUDIT_HASH_USER_ID=false
